    "urn",
    "capability",
    "namespace",
    "validation",
    "matching"
  ],
  "license": "MIT",
  "main": "capdag.js",
  "name": "capdag",
  "repository": {
    "directory": "capdag-js",
    "type": "git",
    "url": "https://github.com/machinefabric/capdag-js.git"
  },
  "scripts": {
